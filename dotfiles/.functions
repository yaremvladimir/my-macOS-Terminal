# Extract archives - use: extract <file>
# Credits to http://dotfiles.org/~pseup/.bashrc
function extract() {
        if [ -f $1 ] ; then
                case $1 in
                        *.tar.bz2) tar xjf $1 ;;
                        *.tar.gz) tar xzf $1 ;;
                        *.bz2) bunzip2 $1 ;;
                        *.rar) rar x $1 ;;
                        *.gz) gunzip $1 ;;
                        *.tar) tar xf $1 ;;
                        *.tbz2) tar xjf $1 ;;
                        *.tgz) tar xzf $1 ;;
                        *.zip) unzip $1 ;;
                        *.Z) uncompress $1 ;;
                        *.7z) 7z x $1 ;;
                        *) echo "'$1' cannot be extracted via extract()" ;;
                esac
        else
                echo "'$1' is not a valid file"
        fi  
}

function jvrs() {
    local jvm_dir="/Library/Java/JavaVirtualMachines"

    # No argument → show current version + list installed JDKs
    if [ -z "$1" ]; then
        echo "Current Java version:"
        java -version 2>&1
        echo
        echo "JAVA_HOME=$JAVA_HOME"
        echo
        echo -n "Available JDK versions: "
        ls "$jvm_dir" | sed -E 's/jdk-([0-9\.]+)\.jdk/\1/' | sort -V | tr '\n' ' '
        echo
        return
    fi

    # Argument provided → attempt to switch
    local jdk_path="$jvm_dir/jdk-$1.jdk"

    if [ -d "$jdk_path" ]; then
        export JAVA_HOME="$jdk_path/Contents/Home"
        echo "Switched JAVA_HOME to $JAVA_HOME"
        java -version 2>&1
    else
        echo "Java version is missing or incorrect: $1"
        echo -n "Installed versions: "
        ls "$jvm_dir" | sed -E 's/jdk-([0-9\.]+)\.jdk/\1/' | sort -V | tr '\n' ' '
        echo
    fi
}

ai() {
  echo "🤖 Copilot thinking..."
  copilot --model gpt-5-mini -p "$*"
}

ai-int() {
  local prompt="$*"
  echo "🤖 Copilot thinking..."
  copilot --model gpt-5-mini -i "$prompt"
}


# AI Command Analyzer Wrapper
ai-cmd-analize() {
    if [ $# -eq 0 ]; then
        echo "Usage: ai-cmd-analize <command>"
        return 1
    fi
    
    # Using $* here treats it as a single printable string
    echo "🤖 Running: $*" 
    echo "-----------------------------------"
    
    # 1. Run the command (Keep $@ here because we WANT the shell to execute separate words)
    local output
    output=$("$@" 2>&1)
    
    # 2. Print the output to the terminal so you can see it
    if [ -z "$output" ]; then
        echo "(No output or empty file)"
    else
        echo "$output"
    fi
    echo "-----------------------------------"
    echo "🧠 Analyzing..."
    
    # 3. Inject the variable using $* so it doesn't break the prompt string into pieces
    copilot --silent --model gpt-5-mini -p "Analyze the execution of this command. 
Command run: $*
Output returned:
$output"
}

